{
  "manifest_version": 3,
  "name": "Job Match AI",
  "version": "0.1.0",
  "description": "Анализ вакансий на match с карьерным профилем через Claude API",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "http://100.64.0.2:8765/*",
    "https://*.linkedin.com/*",
    "https://hh.ru/*",
    "https://career.habr.com/*",
    "https://stackoverflow.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
